# RelayCentralizer service environment examples.
# Copy the relevant section into `central/.env` and `edge/.env`.

# Central
AUTH_TOKEN=change-me
STORAGE_BACKEND=local
BACKUP_ROOT=/backups
RETENTION_KEEP_LAST=3
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=2048
STAGING_DIR=/staging

# Edge
EDGE_ID=edge-01
SCAN_ROOT=/scan
CENTRAL_URL=http://central:8000
AUTH_TOKEN=change-me
INTERVAL_SECONDS=3600
STATE_DIR=/data/state
SPOOL_DIR=/data/spool
LOG_LEVEL=INFO
MAX_DEPTH=10
KEEP_LOCAL_PENDING=true

