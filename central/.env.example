ISSUER_KEY_FILE=relay_issuer.key
# BACKUP_DIR is the host folder Docker mounts into Central at /backups.
BACKUP_DIR=./data/backups
POSTGRES_DB=relaycentral
POSTGRES_USER=relay
POSTGRES_PASSWORD=change-this-password
# Optional: path to a text file listing revoked credential JTIs (one per line).
# REVOKED_CREDENTIALS_FILE=/run/secrets/revoked_credentials
# Optional defaults for the UI-managed ntfy + hook fields when config is blank.
# NTFY_URL=https://ntfy.example.com
# NTFY_TOPIC=uploads
# NTFY_MESSAGE_TEMPLATE=Central received {{ edge_id }}/{{ edge_instance_id }} job {{ job_name }} from {{ source_address }} as {{ stored_as }}.
# NTFY_MATCH_EDGE_ID=
# NTFY_MATCH_EDGE_INSTANCE_ID=
# NTFY_MATCH_SOURCE=
# HOOK_PRE_COMMAND=
# HOOK_POST_COMMAND=
