# Edit these first for your environment.
# EDGE_ID should be unique per Edge installation.
# CENTRAL_URL must be reachable from the Edge container.
EDGE_ID=edge-01
CENTRAL_URL=http://central:8000
# SCAN_DIR is the host folder Docker mounts into Edge at /scan.
SCAN_DIR=./scan
# In the Docker examples, a bare filename is read from ./secrets via /run/secrets.
# Example: ./secrets/central_auth_token.txt -> AUTH_TOKEN_FILE=central_auth_token.txt
AUTH_TOKEN_FILE=relay_auth_token
