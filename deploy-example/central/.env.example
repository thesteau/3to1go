# In the Docker examples, a bare filename is read from ./secrets via /run/secrets.
# Example: ./secrets/relay_auth_token -> AUTH_TOKEN_FILE=relay_auth_token
AUTH_TOKEN_FILE=relay_auth_token
# BACKUP_DIR is the host folder Docker mounts into Central at /backups.
BACKUP_DIR=./data/backups
POSTGRES_DB=relaycentral
POSTGRES_USER=relay
POSTGRES_PASSWORD=change-this-password
