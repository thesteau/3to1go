# BACKUP_DIR is the host folder Docker mounts into Central at /backups.
BACKUP_DIR=./data/backups
POSTGRES_DB=three_to_one_go
POSTGRES_USER=three_to_one_go
POSTGRES_PASSWORD=change-this-password
# Used only when Central creates the first admin user in an empty database.
# If unset, the initial password falls to admin.
INITIAL_ADMIN_PASSWORD=change-this-admin-password
