# Central auto-generates this key on first run if the file does not exist.
# A bare filename is read from ./secrets via /run/secrets.
# Example: ./secrets/relay_issuer.key -> ISSUER_KEY_FILE=relay_issuer.key
ISSUER_KEY_FILE=relay_issuer.key
# BACKUP_DIR is the host folder Docker mounts into Central at /backups.
BACKUP_DIR=./data/backups
POSTGRES_DB=relaycentral
POSTGRES_USER=relay
POSTGRES_PASSWORD=change-this-password
# Optional: path to a text file listing revoked credential JTIs (one per line).
# REVOKED_CREDENTIALS_FILE=/run/secrets/revoked_credentials
