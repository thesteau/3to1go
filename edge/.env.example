# Edit these first for your environment.
# EDGE_ID should be unique per Edge installation.
# CENTRAL_URL must be reachable from the Edge container.
EDGE_ID=edge-01
CENTRAL_URL=http://host.docker.internal:6555
# SCAN_DIR is the host folder Docker mounts into Edge at /scan.
SCAN_DIR=./scan
# In the Docker examples, a bare filename is read from ./secrets via /run/secrets.
# Mint a credential from Central's UI and save it as ./secrets/relay_edge_credential.
# Example: ./secrets/relay_edge_credential -> EDGE_CREDENTIAL_FILE=relay_edge_credential
EDGE_CREDENTIAL_FILE=relay_edge_credential
# Optional defaults for the UI-managed ntfy + hook fields when config is blank.
# NTFY_URL=https://ntfy.example.com
# NTFY_TOPIC=uploads
# NTFY_MESSAGE_TEMPLATE=Edge uploaded {{ edge_id }}/{{ edge_instance_id }} job {{ job_name }} to Central as {{ stored_as }}.
# HOOK_PRE_COMMAND=
# HOOK_POST_COMMAND=
