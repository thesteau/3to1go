# Edit these first for your environment.
# EDGE_ID should be unique per Edge installation.
# CENTRAL_URL must be reachable from the Edge container.
EDGE_ID=edge-01
CENTRAL_URL=http://host.docker.internal:6555
# Used only when Edge creates the first admin user in an empty database.
# If unset, the initial password falls to admin.
INITIAL_ADMIN_PASSWORD=change-this-admin-password
# SCAN_DIR is the host folder Docker mounts into Edge at /scan.
SCAN_DIR=./scan
